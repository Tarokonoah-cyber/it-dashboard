# Copy this file to vercel-dashboard/.env.local for local development.
# Do not commit real keys or passwords.

# Required for all protected dashboard pages and API routes in production.
DASHBOARD_LOGIN_USER=change-me
DASHBOARD_LOGIN_PASSWORD=use-a-strong-password
# Use at least 32 random characters. Rotating this value signs out existing sessions.
DASHBOARD_SESSION_SECRET=replace-with-at-least-32-random-characters

# Required by lib/supabase-rest.js and API routes such as /api/work-logs.
# Use the Supabase project URL and a server-only service role key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional. Only needed if adding client-side Supabase reads in the future.
SUPABASE_ANON_KEY=your-public-anon-key

# Optional legacy / integration settings.
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_ALLOWED_GROUP_ID=
